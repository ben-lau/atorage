{
  "name": "atorage",
  "version": "0.0.1",
  "description": "Atomic storage management library",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./drivers": {
      "import": {
        "types": "./dist/drivers/index.d.mts",
        "default": "./dist/drivers/index.mjs"
      }
    },
    "./middleware": {
      "import": {
        "types": "./dist/middleware/index.d.mts",
        "default": "./dist/middleware/index.mjs"
      }
    },
    "./debug": {
      "import": {
        "types": "./dist/debug/index.d.mts",
        "default": "./dist/debug/index.mjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/test/index.d.mts",
        "default": "./dist/test/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "storage",
    "localStorage",
    "sessionStorage",
    "indexedDB",
    "atomic",
    "middleware"
  ],
  "author": {
    "name": "ben-lau",
    "email": "408736066@qq.com",
    "url": "https://github.com/ben-lau"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
